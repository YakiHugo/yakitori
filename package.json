{
  "name": "yakitori",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm run --parallel \"/^dev:(gui|server)$/\"",
    "dev:gui": "vite --host 127.0.0.1",
    "dev:server": "node src/server/start.ts",
    "build": "pnpm build:lib && pnpm build:gui",
    "build:lib": "vite build --mode lib",
    "build:gui": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "pnpm typecheck && pnpm lint && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.4",
    "openai": "^6.48.0"
  }
}
